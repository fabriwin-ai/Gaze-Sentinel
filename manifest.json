{
  "manifest_version": 3,
  "name": "BARRY METAL NEON SENTINEL — seL4 PROTOCOL",
  "short_name": "Neon Sentinel",
  "version": "1.0.0",
  "description": "ORIGIN-COGNITIVE-OS v0.9 — Real-time gaze tracking cyberpunk HUD",
  "author": "Fabricio Cincunegui",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "ACTIVAR GAZE — seL4 PROTOCOL",
    "default_icon": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self'; object-src 'self';"
  }
}
